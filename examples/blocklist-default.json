      "rm -fr /",
      "rm -fr /*",
      "mkfs",
      "dd",
      ":(){:|:&};:"
    ],
    "RegexPatterns": [
      "^rm\\s+(-rf?|-fr|--recursive)\\s+/\\s*$",
      "^rm\\s+(-rf?|-fr|--recursive)\\s+/\\*\\s*$",
      "^dd\\s+if=.+\\s+of=/dev/(sd[a-z]|nvme[0-9]n[0-9]|vd[a-z]|hd[a-z]|disk[0-9]).*$",
      "^dd\\s+if=/dev/zero\\s+of=/dev/(sd[a-z]|nvme[0-9]n[0-9]|vd[a-z]|disk[0-9]).*$",
      "^>(\\s*)?/dev/(sd[a-z]|nvme[0-9]n[0-9]|vd[a-z]|hd[a-z]).*$",
      "^mkfs\\..*",
      "^(chmod|chown)\\s+(-R|--recursive)\\s+.*/\\s*$",
      ":.*\\(.*\\).*\\{.*\\|.*&.*\\}.*:",
      "(wget|curl).*\\|.*(sh|bash|zsh|fish)\\s*$",
      "^fdisk\\s+/dev/(sd[a-z]|nvme[0-9]n[0-9]|vd[a-z]).*$",
      "^parted\\s+/dev/(sd[a-z]|nvme[0-9]n[0-9]|vd[a-z]).*$",
      "^wipefs\\s+.*",
      "^mv\\s+.*\\s+/dev/null\\s*$",
      "^diskutil\\s+(eraseDisk|partitionDisk|secureErase|zeroDisk)\\s+.*$",
      "^diskutil\\s+apfs\\s+(deleteContainer|deleteVolume)\\s+.*$",
      "^newfs(_hfs|_apfs|_exfat|_msdos|_udf)?\\s+.*$"
    ],
    "BlockedBinaries": [
